Options -Indexes
RewriteEngine On

# Return 404 (not 403) for direct requests to any .php file except index.php
RewriteCond %{REQUEST_URI} \.php$
RewriteCond %{REQUEST_URI} !/index\.php$
RewriteRule ^ - [R=404,L]

# Route all other non-file requests through index.php
RewriteCond %{REQUEST_FILENAME} !-f
RewriteRule ^ index.php [L]
