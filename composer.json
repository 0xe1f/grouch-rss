{
    "name": "grouch/rss",
    "description": "RSS feed generators for local cinema listings",
    "type": "project",
    "require": {
        "php": ">=8.1",
        "ext-curl": "*",
        "ext-json": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^11"
    },
    "autoload": {
        "psr-4": {
            "Grouch\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Grouch\\Tests\\": "tests/"
        }
    },
    "config": {
        "optimize-autoloader": true
    }
}
